{
  "redirects": [
    {
      "source": "/",
      "destination": "/apps/eduos-landing/",
      "permanent": false
    },
    {
      "source": "/apps/edoos-:path*",
      "destination": "/apps/eduos-:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/atheer",
      "destination": "https://eduos-core.vercel.app/atheer"
    },
    {
      "source": "/atheer/:path*",
      "destination": "https://eduos-core.vercel.app/atheer/:path*"
    },
    {
      "source": "/characters/:path*",
      "destination": "https://eduos-core.vercel.app/characters/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-duties",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/cron/daily-substitutions",
      "schedule": "0 3 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 6 * * 5"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 1 */3 * *"
    }
  ]
}
